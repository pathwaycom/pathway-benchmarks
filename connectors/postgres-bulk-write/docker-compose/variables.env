# Total rows in the dataset (split across CSV shards).
DATASET_SIZE=20000000

# Rows committed per transaction / per COPY stream.
BATCH_SIZE=10000

# Pathway worker count. The run script overrides this per measured worker count.
PATHWAY_THREADS=1

# Core pinning, tuned for an AMD Ryzen 9 5900X (Zen 3): one NUMA node, two CCDs
# of 6 cores each, every CCD with its own 32 MiB L3. Identical to the QuestDB
# benchmark so the two are comparable: the database owns CCD 0 /
# L3 #0 (cores 0-5 plus their SMT siblings 12-17) and the Pathway engine owns
# CCD 1 / L3 #1 (cores 6-11 plus 18-23). Each service therefore gets a private L3
# and never shares a physical core with the other; the largest worker count
# measured (8) fits on CCD 1. Everything stays on the single NUMA node. Adjust to
# your topology (see README "Machine specs": `lscpu`, and the per-core L3
# `shared_cpu_list` under /sys/devices/system/cpu/*/cache/index3/).
POSTGRES_CPUSET=0-5,12-17
PATHWAY_CPUSET=6-11,18-23

# Host port the Postgres container is exposed on (for verification only).
POSTGRES_HOST_PORT=55433
