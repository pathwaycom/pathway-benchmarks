# Total rows in the dataset (split across CSV shards).
DATASET_SIZE=20000000

# Rows committed per transaction.
BATCH_SIZE=10000

# Pathway worker count. The run script overrides this per measured worker count.
PATHWAY_THREADS=1

# Core pinning, tuned for an AMD Ryzen 9 5900X (Zen 3): one NUMA node, two CCDs
# of 6 cores each, every CCD with its own 32 MiB L3. SQLite is embedded (no
# server), so only the Pathway engine is pinned — to CCD 1 / L3 #1 (cores 6-11
# plus SMT siblings 18-23), the same CCD the engine uses in the other
# benchmarks, so single-worker numbers are comparable. Everything stays on the
# single NUMA node. Adjust to your topology (see README "Machine specs").
PATHWAY_CPUSET=6-11,18-23
